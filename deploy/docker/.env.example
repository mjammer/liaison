# Public host or IP that edges and browsers will reach this deployment at.
# Used as the TLS cert CN and baked into the web console's own URL.
LIAISON_PUBLIC_HOST=your-public-ip-or-domain

# Liaison Web console port. Containers run in host network mode, so this
# is the port directly bound on the host. Default 443 (HTTPS).
MANAGER_PORT=443

# Frontier edgebound port — connectors dial this to reach the gateway.
# Bound on the host (not via docker-proxy).
FRONTIER_PORT=30012

# Frontier controlplane port — liaison uses this local loopback endpoint to
# actively disconnect deleted connectors. Keep it closed to the public network.
FRONTIER_CONTROLPLANE_PORT=30010

# guacd runs in host network mode and connects back to a short-lived manager
# bridge for WebDesktop traffic. Keep these loopback defaults.
GUACD_ADDR=127.0.0.1:4822
GUACD_BRIDGE_ADDR=127.0.0.1:0
GUACD_BRIDGE_HOST=127.0.0.1

# First-run admin account email. Password is auto-generated on first start
# and printed once to `docker compose logs liaison` — save it.
LIAISON_ADMIN_EMAIL=default@liaison.com

# Image tag / registry — leave defaults for local builds.
LIAISON_IMAGE_REGISTRY=liaison
LIAISON_IMAGE_TAG=latest
